# Minimal image for saap.gateway (FastAPI). Multi-stage keeps the
# runtime image free of build tooling.
FROM python:3.11-slim AS base

WORKDIR /app

COPY pyproject.toml ./
COPY saap ./saap

RUN pip install --no-cache-dir .

EXPOSE 8000

CMD ["uvicorn", "saap.gateway.app:app", "--host", "0.0.0.0", "--port", "8000"]
